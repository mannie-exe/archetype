    <!-- Cells -->
    <theme name="cell" ref="label">
      <param name="background">
        <image>ui-inputbox.background</image>
      </param>
      <param name="textAlignment">
        <enum type="alignment">LEFT</enum>
      </param>
      <param name="border">
        <border>5</border>
      </param>
    </theme>
    <theme name="cell-markup" ref="label">
      <param name="font">
        <font>alphabeta-markup</font>
      </param>
      <param name="background">
        <image>ui-inputbox.background</image>
      </param>
      <param name="textAlignment">
        <enum type="alignment">CENTER</enum>
      </param>
    </theme>
    <theme name="cell-warn" ref="label">
      <param name="font">
        <font>alphabeta-yellow</font>
      </param>
      <param name="background">
        <image>ui-inputbox.background</image>
      </param>
      <param name="textAlignment">
        <enum type="alignment">LEFT</enum>
      </param>
      <param name="border">
        <border>5</border>
      </param>
      <param name="minWidth">
        <int>96</int>
      </param>
      <param name="minWidth">
        <int>50</int>
      </param>
    </theme>
    <theme name="cell-danger" ref="label">
      <param name="font">
        <font>alphabeta-red</font>
      </param>
      <param name="background">
        <image>ui-inputbox.background</image>
      </param>
      <param name="textAlignment">
        <enum type="alignment">LEFT</enum>
      </param>
      <param name="border">
        <border>5</border>
      </param>
      <param name="minWidth">
        <int>96</int>
      </param>
      <param name="minWidth">
        <int>50</int>
      </param>
    </theme>
    <theme name="cell-positive" ref="label">
      <param name="font">
        <font>alphabeta-darkgreen</font>
      </param>
      <param name="background">
        <image>ui-inputbox.background</image>
      </param>
      <param name="textAlignment">
        <enum type="alignment">LEFT</enum>
      </param>
      <param name="border">
        <border>5</border>
      </param>
      <param name="minWidth">
        <int>50</int>
      </param>
    </theme>
    <theme name="cell-button" ref="cell">
      <param name="background">
        <image>ui-button.background</image>
      </param>
      <param name="textAlignment">
        <enum type="alignment">CENTER</enum>
      </param>
    </theme>
    <theme name="cell-button-addon" ref="cell-button">
      <param name="textAlignment">
        <enum type="alignment">LEFT</enum>
      </param>
    </theme>
    <theme name="cell-icon" ref="label">
      <param name="background">
        <image>ui-inputbox.background</image>
      </param>
      <param name="textAlignment">
        <enum type="alignment">CENTER</enum>
      </param>
      <param name="border">
        <border>0</border>
      </param>
      <param name="minWidth">
        <int>24</int>
      </param>
    </theme>
    <!-- special cells -->
    <theme name="button-monster" ref="button">
      <param name="background">
        <image>ui-inputbox.background</image>
      </param>
      <param name="border">
        <border>2,0</border>
      </param>
      <param name="minWidth">
        <int>0</int>
      </param>
      <param name="minHeight">
        <int>0</int>
      </param>
    </theme>
    <theme name="button-species" ref="button">
      <param name="">
        <image>ui-button.*</image>
      </param>
      <param name="border">
        <border>8,2</border>
      </param>
    </theme>

    <theme name="editfield" ref="editfield">
      <param name="textAlignment">
        <enum type="alignment">RIGHT</enum>
      </param>
      <param name="autocompletion-height">
        <int>150</int>
      </param>
    </theme>
    <theme name="editfield-red" ref="editfield">
      <param name="font">
        <font>pb-dark-red</font>
      </param>
    </theme>
    <theme name="valueadjuster" ref="valueadjuster" allowWildcard="true">
      <param name="width">
        <int>92</int>
      </param>
    </theme>
  </theme>

  <theme name="category-view" ref="-defaults">
    <param name="border">
      <border>27,0,5,5</border>
    </param>
    <theme name="category-view-inner" ref="-defaults">
      <param name="background">
        <image>ui-tab.background</image>
      </param>
      <param name="border">
        <border>0,10,10,5</border>
      </param>
      <param name="namedGaps">
        <map/>
      </param>
      <theme name="label" ref="label" allowWildcard="true">
        <param name="border">
          <border>10,10,0,0</border>
        </param>
        <param name="background">
          <image>none</image>
        </param>
      </theme>
      <theme name="dialoglayout" ref="-defaults">
        <theme name="label-info" ref="label">
          <param name="background">
            <image>ui-inputbox.background</image>
          </param>
          <param name="textAlignment">
            <enum type="alignment">CENTER</enum>
          </param>
          <param name="border">
            <border>6</border>
          </param>
          <param name="minWidth">
            <int>300</int>
          </param>
          <param name="minHeight">
            <int>100</int>
          </param>
        </theme>
      </theme>
    </theme>
  </theme>

  <theme name="broker-window" ref="base-tabbed-frame">
    <param name="background">
      <image>GTL-Window</image>
    </param>
    <param name="minWidth">
      <int>900</int>
    </param>
    <param name="minHeight">
      <int>605</int>
    </param>
    <theme name="tabbedpane" ref="base-tabbed-pane">
      <theme name="tabbox" ref="tabbox">
        <theme name="tabbutton" ref="tabbutton"></theme>
      </theme>
      <theme name="container" ref="container">
        <param name="border">
          <border>10,10,10,6</border>
        </param>
        <param name="namedGaps">
          <map/>
        </param>
        <theme name="editfield" ref="editfield-search"></theme>
        <theme name="label" ref="label" allowWildcard="true">
          <param name="border">
            <border>10,10,0,0</border>
          </param>
          <param name="background">
            <image>none</image>
          </param>
        </theme>
        <theme name="dialoglayout" ref="dialoglayout">
          <theme name="label-info" ref="label">
            <param name="background">
              <image>ui-inputbox.background</image>
            </param>
            <param name="textAlignment">
              <enum type="alignment">CENTER</enum>
            </param>
            <param name="border">
              <border>30</border>
            </param>
          </theme>
        </theme>
      </theme>
      <param name="inputMap">
        <inputMapDef>
          <action name="nextTab">CTRL TAB</action>
          <action name="prevTab">CTRL SHIFT TAB</action>
        </inputMapDef>
      </param>
    </theme>
  </theme>
</themes>
