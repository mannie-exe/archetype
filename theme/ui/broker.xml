<?xml version="1.0" encoding="UTF-8"?>
<themes>
  <theme name="broker-table" ref="-defaults">
    <param name="background">
      <image>none</image>
    </param>
    <param name="border">
      <border>0,0,0,0</border>
    </param>
    <param name="defaultGap">
      <dimension>5,5</dimension>
    </param>
    <param name="smallGap">
      <dimension>8,8</dimension>
    </param>
    <param name="mediumGap">
      <dimension>10,10</dimension>
    </param>
    <param name="largeGap">
      <dimension>15,15</dimension>
    </param>
    <param name="namedGaps">
      <map/>
    </param>

    <theme name="label-info" ref="label">
      <param name="textAlignment">
        <enum type="alignment">CENTER</enum>
      </param>
      <param name="border">
        <border>0</border>
      </param>
    </theme>

    <theme name="button" ref="button">
      <param name="minWidth">
        <int>100</int>
      </param>
      <param name="width">
        <int>100</int>
      </param>
      <param name="textAlignment">
        <enum type="alignment">LEFT</enum>
      </param>
    </theme>

    <!-- Sorting / Header columns -->
    <theme name="header-column" ref="label">
      <param name="background">
        <image>ui-header.background</image>
      </param>
      <param name="textAlignment">
        <enum type="alignment">CENTER</enum>
      </param>
    </theme>
    <theme name="header-column-sort-default" ref="header-column">
      <param name="overlay">
        <image>ui-sort-default.background</image>
      </param>
    </theme>
    <theme name="header-column-sort-desc" ref="header-column">
      <param name="overlay">
        <image>ui-sort-asc.background</image>
      </param>
    </theme>
    <theme name="header-column-sort-asc" ref="header-column">
      <param name="overlay">
        <image>ui-sort-desc.background</image>
      </param>
    </theme>

