<?xml version="1.0" encoding="UTF-8"?>
<themes>
  <!--<images file="res/custom/2sTxAVRCoW/PC-Slot-Disabled.png" filter="nearest">
		<area name="Incubator-Disabled" xywh="*"/>
  </images>-->
	
  <theme name="incubator-frame" ref="new-base-frame">
  <param name="background"><image>Incubator-Window</image></param>
    <param name="border"><border>35,10,10,10</border></param>
    <param name="minHeight"><int>190</int></param>
		<param name="titleAreaTop"><int>0</int></param>
		<param name="titleAreaLeft"><int>1</int></param>
		<param name="titleAreaRight"><int>-1</int></param>
		<param name="titleAreaBottom"><int>-1</int></param>
    <!--<theme name="title" ref="title">
      <param name="border"><border>9,10,2,0</border></param>
    </theme>-->
    <theme name="incubator-main-table" ref="table">
	<!-- gray background accent -->
      <!--<param name="background"><image>incubator.background</image></param>-->
	  <param name="background"><image>none</image></param>
      <theme name="incubator-slot" ref="-defaults">
        <param name=""><image>pc-slot.*</image></param>
        <param name="minWidth"><int>62</int></param>
        <param name="minHeight"><int>62</int></param>
        <theme name="incubator-temporary-uses" ref="-defaults" allowWildcard="true">
          <param name=""><image>mi-hpbar-green.*</image></param>
          <param name="border"><border>0</border></param>
          <param name="minWidth"><int>100</int></param>
        </theme>
      </theme>
      <theme name="empty-incubator-slot" ref="incubator-slot">
	  <param name="background"><image>incubator-slot.background</image></param>
	  <!--<param name="background"><image>ui-frame.background</image></param>-->
	  <!--<param name="background"><image>Incubator-Disabled</image></param>-->
	 
        <param name="maxWidth"><int>62</int></param>
        <param name="maxHeight"><int>62</int></param>
      </theme>

      <theme name="button" ref="button">
        <param name="border"><border>6</border></param>
      </theme>
      <theme name="incubator-monster-slot" ref="incubator-slot"/>
      <theme name="desc-label" ref="label">
        <param name="background"><image>ui-inputbox.background</image></param>
        <param name="textAlignment"><enum type="alignment">center</enum></param>
        <param name="border"><border>6</border></param>
        <param name="minWidth"><int>180</int></param>
        <param name="minHeight"><int>355</int></param>
      </theme>
    </theme>
  </theme>
</themes>