<?xml version="1.0" encoding="UTF-8"?>
<themes>
	<!-- social window -->
	<theme name="social-window" ref="base-tabbed-frame">
		<param name="fadeDurationShow"><int>200</int></param>
		<param name="fadeDurationHide"><int>200</int></param>
		<theme name="dialoglayout" ref="dialoglayout">
			<theme name="tabbedpane" ref="base-tabbed-pane">
				<param name="inputMap"><inputMapDef>
					<action name="nextTab">CTRL TAB</action>
					<action name="prevTab">CTRL SHIFT TAB</action>
				</inputMapDef></param>
			</theme>
		</theme>
	</theme>
	
	
	<theme name="mail-window" ref="base-tabbed-frame">
		<param name="background"><image>Mail-Window</image></param>
		<param name="fadeDurationShow"><int>200</int></param>
		<param name="fadeDurationHide"><int>200</int></param>
		<theme name="dialoglayout" ref="dialoglayout">
			<theme name="tabbedpane" ref="base-tabbed-pane">
				<theme name="tabbox" ref="tabbox">
					<theme name="tabbutton" ref="tabbutton">
						<param name="background"><image>ui-tab.background</image></param>
					</theme>
				</theme>
				<theme name="container" ref="container">
					<param name="background"><image>none</image></param>
					 <theme name="dialoglayout" ref="dialoglayout">
						<param name="border"><border>10,10,7,10</border></param>
						<param name="namedGaps"><map/></param>
						<param name="background"><image>none</image></param>
		
						<!-- roster -->
						<theme name="label" ref="label" allowWildcard="true">
							<param name="border"><border>0,0,10,0</border></param>
							<param name="background"><image>none</image></param>
						</theme>

						<theme name="pager" ref="pager">
							<param name="border"><border>0,0,10,0</border></param>
						</theme>
					</theme>
				</theme>
				<param name="inputMap"><inputMapDef>
					<action name="nextTab">CTRL TAB</action>
					<action name="prevTab">CTRL SHIFT TAB</action>
				</inputMapDef></param>
			</theme>
		</theme>
	</theme>

	<theme name="mail-inner" allowWildcard="true">
		<param name="background"><image>none</image></param>
		<param name="overlay"><image>none</image></param>
		<theme name="hscrollbar" ref="hscrollbar"/>  <!-- not used -->
		<theme name="vscrollbar" ref="vscrollbar-white"/>
		<param name="minWidth"><int>445</int></param>
		<param name="minHeight"><int>400</int></param>
		<param name="maxWidth"><int>32767</int></param>
		<param name="maxHeight"><int>32767</int></param>
		<param name="hasDragButton"><bool>false</bool></param>
		<param name="autoScrollArea"><int>5</int></param>
		<param name="autoScrollSpeed"><int>10</int></param>
		<param name="scrollbarsAlwaysVisible"><bool>false</bool></param>
		<theme name="dialoglayout" ref="-defaults">
      <param name="defaultGap"><dimension>4,2</dimension></param>
      <param name="smallGap"><dimension>8,8</dimension></param>
      <param name="mediumGap"><dimension>10,10</dimension></param>
      <param name="largeGap"><dimension>15,15</dimension></param>
      <param name="namedGaps"><map/></param>
      <param name="headerRowBackground"><image>ui-header.background</image></param>
      <param name="contentRowBackground"><image>ui-inputbox.background</image></param>
      <theme name="button" ref="button" allowWildcard="true">
        <param name="border"><border>6</border></param>
      </theme>
      <theme name="button-row" ref="button" allowWildcard="true">
        <param name="background"><image>none</image></param>
        <param name="border"><border>6</border></param>
      </theme>
      <theme name="button-small2" ref="button" allowWildcard="true">
				<param name="minWidth"><int>100</int></param>
			</theme>
      <theme name="label-value" ref="label" allowWildcard="true">
        <param name="background"><image>none</image></param>
        <param name="textAlignment"><enum type="alignment">CENTER</enum></param>
        <param name="border"><border>6</border></param>
      </theme>
      <theme name="label-title" ref="label-value" allowWildcard="true">
        <param name="background"><image>none</image></param>
        <param name="border"><border>6</border></param>
        <param name="textAlignment"><enum type="alignment">CENTER</enum></param>
      </theme>
      <theme name="label-field" ref="label-value" allowWildcard="true">
        <param name="minWidth"><int>125</int></param>
        <param name="background"><image>ui-header.background</image></param>
        <param name="border"><border>6</border></param>
        <param name="textAlignment"><enum type="alignment">CENTER</enum></param>
      </theme>
			<theme name="scrollpane" ref="scrollpane">
				<theme name="hscrollbar" ref="hscrollbar"/>
				<theme name="editfield" ref="body-editfield">
					<param name="textAlignment"><enum type="alignment">TOPLEFT</enum></param>
					<param name="autocompletion-height"><int>150</int></param>
					<param name="minWidth"><int>265</int></param>
					<param name="minHeight"><int>100</int></param>
				</theme>
			</theme>
			<theme name="editfield" ref="editfield">
				<param name="textAlignment"><enum type="alignment">RIGHT</enum></param>
				<param name="autocompletion-height"><int>150</int></param>
				<param name="minWidth"><int>250</int></param>
				<param name="font"><font>title-font</font></param>
			</theme>
		</theme>
	</theme>

	<theme name="read-mail" ref="mail-inner">
    <theme name="item-slot" ref="-defaults">
      <param name="background"><image>ui-button.background</image></param>
      <param name="textAlignment"><enum type="alignment">bottom</enum></param>
      <param name="border"><border>0,0,2,0</border></param>
    </theme>
    <theme name="monster-slot" ref="-defaults">
      <param name="background"><image>ui-button.background</image></param>
      <param name="textAlignment"><enum type="alignment">bottom</enum></param>
      <param name="border"><border>0,0,2,0</border></param>
    </theme>
    <theme name="spritelabel" ref="spritelabel" allowWildcard="true"/>
    <theme name="button" ref="button"/>
    <theme name="editfield" ref="editfield">
      <param name="background"><image>ui-header.background</image></param>
      <param name="minHeight"><int>26</int></param>
      <theme name="renderer" ref="renderer">
        <param name="border"><border>4,5</border></param>
        <param name="textAlignment"><enum type="alignment">TOPLEFT</enum></param>
      </theme>
    </theme>
    <theme name="body-editfield" ref="editfield">
      <param name="minWidth"><int>150</int></param>
    </theme>
    <theme name="button-small2" ref="button" allowWildcard="true">
      <param name="minWidth"><int>100</int></param>
    </theme>
    <!-- Value -->
    <theme name="label-value" ref="label" allowWildcard="true">
      <param name="background"><image>none</image></param>
      <param name="textAlignment"><enum type="alignment">left</enum></param>
      <param name="border"><border>6</border></param>
    </theme>
    <theme name="label-title" ref="label-value" allowWildcard="true">
      <param name="background"><image>none</image></param>
      <param name="textAlignment"><enum type="alignment">CENTER</enum></param>
      <param name="border"><border>6</border></param>
    </theme>
  </theme>
	<theme name="write-mail" ref="mail-inner"/>
</themes>
